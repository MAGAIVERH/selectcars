# Copy to `.env` and fill in. Never commit `.env`.

# --- Database (Supabase Postgres) --------------------------------------------
# Use the SESSION POOLER host, not the direct `db.<ref>.supabase.co` one: the direct
# host is IPv6-only and will not resolve on most IPv4 networks.
# Find it in: Supabase dashboard > Connect > Session pooler.
# Special characters in the password must be URL-encoded (`@` becomes `%40`).
#
# Named SELECTCARS_DATABASE_URL rather than DATABASE_URL on purpose: a generic
# DATABASE_URL in your shell (some tools export one) would silently take precedence, and a
# migration would land in the wrong database. That happened once. On top of the rename,
# `packages/db/src/guard.ts` hard-refuses any host that is not this project's Supabase, so
# the mistake is now impossible rather than merely unlikely.
SELECTCARS_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# --- Better Auth (the marketplace app is the identity issuer) ------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=<32-byte-base64-secret>
BETTER_AUTH_URL=http://localhost:3000

# --- Google OAuth --------------------------------------------------------------
# Google Cloud Console > Credentials > OAuth client (Web application).
# Authorized redirect URI must be exactly:
#   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=<client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<client-secret>

# --- Fastify API ---------------------------------------------------------------
API_PORT=3333
API_HOST=0.0.0.0
# Origin allowed by CORS (the marketplace).
APP_ORIGIN=http://localhost:3000
# Identity issuer the API verifies tokens against. This is a NAME, matched against the
# token's `iss`/`aud` claims: it must equal the marketplace's BETTER_AUTH_URL exactly.
AUTH_ISSUER_URL=http://localhost:3000

# Optional. Where to FETCH the issuer's public keys, when that address differs from the
# issuer's name. Defaults to `${AUTH_ISSUER_URL}/api/auth/jwks`.
# docker-compose sets it to http://host.docker.internal:3000/api/auth/jwks, because inside
# a container `localhost` is the container itself, not your machine.
# AUTH_JWKS_URL=http://host.docker.internal:3000/api/auth/jwks

# --- Redis (BullMQ, Phase 3) ---------------------------------------------------
# Port 6380, not the default 6379: docker-compose maps it there so this project's Redis
# can run alongside another project's Redis on the same machine.
# (Inside docker-compose the API uses `redis://redis:6379` and ignores this value.)
REDIS_URL=redis://localhost:6380
